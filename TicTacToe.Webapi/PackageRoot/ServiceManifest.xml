		</EntryPoint>
	</CodePackage>

	<!--<ConfigPackage Name="Config" Version="1.0.0" />-->

	<Resources>
		<Endpoints>
			<!--<Endpoint Protocol="http" Name="ServiceEndpoint" Type="Input" Port="8081"/>-->
			<Endpoint Protocol="http" Name="ServiceEndpoint" Type="Input" />
		</Endpoints>
	</Resources>
