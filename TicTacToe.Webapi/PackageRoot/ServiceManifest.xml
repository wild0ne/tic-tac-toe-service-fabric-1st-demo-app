<?xml version="1.0" encoding="utf-8"?>
<ServiceManifest Name="TicTacToe.WebapiPkg"
                 Version="1.0.29"
                 xmlns="http://schemas.microsoft.com/2011/01/fabric"
                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"
